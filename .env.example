# ── Bot Credentials ─────────────────────────────────
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# ── (Opsional) Guild ID untuk deploy command saat development ──
# Isi ini supaya slash command langsung aktif di server tertentu (tidak perlu tunggu 1 jam)
# Kosongkan untuk deploy global
GUILD_ID=your_guild_id_here

# ── Catatan ─────────────────────────────────────────
# Welcome, Goodbye, Log channel, dan Muted Role kini dikonfigurasi
# langsung di Discord menggunakan slash command /config
# Tidak perlu diisi di sini lagi.
